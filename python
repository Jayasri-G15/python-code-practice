    {
      "cell_type": "code",
      "source": [
        "def find_paths(maze, m, n, x, y):\n",
        "    # invalid cases\n",
        "    if x >= m or y >= n or maze[x][y] == 1:\n",
        "        return 0\n",
        "\n",
        "    # reached destination\n",
        "    if x == m - 1 and y == n - 1:\n",
        "        return 1\n",
        "\n",
        "    # move down + move right\n",
        "    return find_paths(maze, m, n, x + 1, y) + find_paths(maze, m, n, x, y + 1)\n",
        "\n",
        "\n",
        "maze = [\n",
        "    [0, 0, 0],\n",
        "    [0, 1, 0],\n",
        "    [0, 0, 0]\n",
