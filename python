    {
      "cell_type": "code",
      "source": [
        "def bSearch(elem, arr):\n",
        "    start, end = 0, len(arr) - 1\n",
        "\n",
        "    while start <= end:\n",
        "        mid = (start + end) // 2\n",
        "\n",
        "        if arr[mid] == elem:\n",
        "            return True\n",
        "        elif arr[mid] < elem:\n",
        "            start = mid + 1\n",
        "        else:\n",
        "            end = mid - 1\n",
        "\n",
        "    return False\n",
        "\n",
        "\n",
        "def isSubset(arr1, arr2):\n",
        "    if len(arr1) > len(arr2):\n",
        "        return False\n",
        "\n",
        "    arr2.sort()\n",
        "\n",
        "    for x in arr1:\n",
        "        if not bSearch(x, arr2):\n",
        "            return False\n",
        "\n",
        "    return True\n",
        "\n",
        "\n",
        "arr1 = [1, 3, 4, 5, 2]\n",
        "arr2 = [2, 4, 3, 1, 7, 5, 15]\n",
        "\n",
        "print(isSubset(arr1, arr2))"
