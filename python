    {
      "cell_type": "markdown",
      "source": [
        "What Is Equilibrium Index?\n",
        "\n",
        "👉 An index where:\n",
        "\n",
        "Sum of elements on left = Sum of elements on right"
      ],
      "metadata": {
        "id": "IUDGAAaIndWu"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "arr = list(map(int, input().split()))\n",
        "\n",
        "total = sum(arr)\n",
        "left_sum = 0\n",
        "\n",
        "for i in range(len(arr)):\n",
        "    right_sum = total - left_sum - arr[i]\n",
        "\n",
        "    if left_sum == right_sum:\n",
        "        print(\"Equilibrium index:\", i)\n",
        "        break\n",
        "\n",
        "    left_sum += arr[i]\n",
        "else:\n",
        "    print(\"No equilibrium index found\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
